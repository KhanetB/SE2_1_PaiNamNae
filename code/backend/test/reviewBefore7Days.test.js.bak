test("TC05 Review after 7 days", async function() {
  const review_res = await axios.post("http://localhost:3000/api/reviews", {
  "bookingId": booking_id,
  "rating": 4.5,
  "comment":"Great ride, very comfortable and the driver was friendly!",
  "now": new Date(new Date().getTime() + 7 * 24 * 60 * 60 * 1000).now // 7 days later
  },{
