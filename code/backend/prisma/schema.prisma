datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PASSENGER
  DRIVER
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RouteStatus {
  AVAILABLE
  FULL
  COMPLETED
  CANCELLED
  IN_TRANSIT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_TRANSIT
  PASSENGER_CONFIRMED_ARRIVAL
  COMPLETED
  REJECTED
  CANCELLED
}

enum CancelReason {
  CHANGE_OF_PLAN // เปลี่ยนแผน/มีธุระกะทันหัน
  FOUND_ALTERNATIVE // พบวิธีเดินทางอื่นแล้ว
  DRIVER_DELAY // คนขับล่าช้าหรือเลื่อนเวลา
  PRICE_ISSUE // ราคาหรือค่าใช้จ่ายไม่เหมาะสม
  WRONG_LOCATION // เลือกจุดรับ–ส่งผิด
  DUPLICATE_OR_WRONG_DATE // จองซ้ำหรือจองผิดวัน
  SAFETY_CONCERN // กังวลด้านความปลอดภัย
  WEATHER_OR_FORCE_MAJEURE // สภาพอากาศ/เหตุสุดวิสัย
  COMMUNICATION_ISSUE // สื่อสารไม่สะดวก/ติดต่อไม่ได้
}

enum LicenseType {
  PRIVATE_CAR_TEMPORARY // รถยนต์ส่วนบุคคลชั่วคราว (2 ปี)
  PRIVATE_CAR // รถยนต์ส่วนบุคคล (5 ปี)
  PUBLIC_CAR // รถยนต์สาธารณะ
  LIFETIME // ตลอดชีพ
}

enum NotificationType {
  SYSTEM
  VERIFICATION
  BOOKING
  ROUTE
}

enum ReviewLabel {
  SAFE_DRIVING        // ขับขี่ปลอดภัย
  CLEAN_CAR           // สะอาด รถน่านั่ง
  FRIENDLY_DRIVER     // คนขับอัธยาศัยดี
  GOOD_MUSIC          // ชอบเพลงที่เปิด
}

enum ReviewFileType {
  IMAGE
  VIDEO
}

enum ActionType {
  UNKNOWN
  // AUTHENTICATION
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGED
  // USER 
  USER_REGISTERED
  USER_DELETED
  PROFILE_VIEWED
  PROFILE_UPDATED
  USER_DATA_EXPORT_REQUESTED

  // VEHICLE
  VEHICLE_CREATED
  VEHICLE_UPDATED
  VEHICLE_DELETED
  VEHICLE_VIEWED

  // BOOKING
  BOOKING_CREATED
  BOOKING_UPDATED
  BOOKING_DELETED
  BOOKING_VIEWED

  // ROUTE 
  ROUTE_CREATED
  ROUTE_UPDATED
  ROUTE_VIEWED
  ROUTE_DELETE

  // REVIEW 
  REVIEW_CREATED

  // DRIVER VERIFICATION
  DRIVER_VERIFICATION_SUBMITTED
  DRIVER_VERIFICATION_UPDATED
  DRIVER_LICENSES_VIEWED

  // Admin Actions
  ADMIN_VIEWED
  ADMIN_CREATED
  ADMIN_UPDATED
  ADMIN_DELETED
  ADMIN_LOG_VIEWED
  ADMIN_LOG_EXPORTED

  // System
  SYSTEM_ERROR
}

enum AccessResult {
  SUCCESS
  ERROR
  DENIED
}

model AuditLog {
  id           String  @id @default(cuid())
  // ข้อกำหนด: ข้อมูลในการระบุตัวตนผู้ใช้
  userId       String?
  user         User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // ข้อกำหนด: วันเวลาและรายละเอียดเหตุการณ์สำคัญ
  action          ActionType
  actionTimeStamp DateTime // UTC, NTP-Synced

  // ข้อกำหนด: ข้อมูลอุปกรณ์และเครือข่าย
  ipAddress  String // support ipv4 and ipv6
  userAgent  String
  deviceInfo String?

  // ข้อกำหนด: รายละเอียดการใช้งาน
  httpMethod     String?
  endpoint       String
  resourceType   String
  // ข้อกำหนด: success or defined
  accessResult   AccessResult
  httpStatusCode String

  // ข้อกำหนด: รายละเอียดเพิ่มเติม
  metaData       Json?   @db.Json
  errorMessage   String?
  integrityHash String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([ipAddress])
  @@index([action])
  @@index([accessResult])
}

model User {
  id                      String              @id @default(cuid())
  username                String              @unique
  email                   String              @unique
  password                String
  firstName               String?
  lastName                String?
  gender                  String?
  phoneNumber             String?
  profilePicture          String?
  nationalIdNumber        String?             @unique
  nationalIdPhotoUrl      String?             @unique
  nationalIdExpiryDate    DateTime?
  selfiePhotoUrl          String?
  role                    Role                @default(PASSENGER)
  isVerified              Boolean             @default(false)
  isActive                Boolean             @default(true)
  otpCode                 String?
  deleteOtp               String?
  deleteOtpExpiresAt      DateTime?
  lastLogin               DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  passengerSuspendedUntil DateTime?
  driverSuspendedUntil    DateTime?
  driverVerification      DriverVerification?
  vehicles                Vehicle[]
  notification            Notification[]
  createdRoutes           Route[]             @relation("DriverRoutes")
  bookings                Booking[]           @relation("PassengerBookings")
  deletedAt               DateTime?          
  deletedBy               String?           

  PassengerReviews        Review[]            @relation("PassengerReviews")
  DriverReviews           Review[]            @relation("DriverReviews")

  auditLog         AuditLog[]

  @@index([role])
  @@index([isActive])
  @@index([isVerified])
  @@index([createdAt])
  @@index([deletedAt])
}

model DriverVerification {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber      String             @unique
  firstNameOnLicense String
  lastNameOnLicense  String
  licenseIssueDate   DateTime
  licenseExpiryDate  DateTime
  licensePhotoUrl    String
  selfiePhotoUrl     String
  typeOnLicense      LicenseType
  status             VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([licenseIssueDate])
  @@index([licenseExpiryDate])
}

model Notification {
  id     String @id @default(cuid())
  userId String? 
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  type     NotificationType @default(SYSTEM)
  title    String
  body     String
  link     String?
  metadata Json?            @db.Json

  readAt          DateTime?
  createdAt       DateTime  @default(now())
  adminReviewedAt DateTime?

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([adminReviewedAt])
}

model Vehicle {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleModel String
  licensePlate String   @unique
  vehicleType  String
  color        String
  seatCapacity Int
  amenities    String[]
  photos       Json?    @db.Json
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  routes Route[]

  @@index([userId])
  @@index([createdAt])
  @@index([vehicleType])
  @@index([seatCapacity])
}

model Route {
  id              String      @id @default(cuid())
  driverId        String?
  driver          User?        @relation("DriverRoutes", fields: [driverId], references: [id], onDelete: SetNull)
  vehicleId       String?
  vehicle         Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  startLocation   Json        @db.Json
  endLocation     Json        @db.Json
  departureTime   DateTime
  availableSeats  Int
  pricePerSeat    Float
  conditions      String?
  status          RouteStatus @default(AVAILABLE)
  cancelledAt     DateTime?
  cancelledBy     String? // 'DRIVER' | 'ADMIN'
  routePolyline   String?
  distanceMeters  Int?
  durationSeconds Int?
  routeSummary    String?
  distance        String?
  duration        String?
  waypoints       Json?       @db.Json
  landmarks       Json?       @db.Json
  steps           Json?       @db.Json
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  startedAt       DateTime?
  completedAt     DateTime?

  bookings Booking[]

  @@index([driverId])
  @@index([vehicleId])
  @@index([status])
  @@index([createdAt])
  @@index([departureTime])
}

model Booking {
  id              String        @id @default(cuid())
  routeId         String?
  route           Route?         @relation(fields: [routeId], references: [id], onDelete: SetNull)
  passengerId     String?
  passenger       User?          @relation("PassengerBookings", fields: [passengerId], references: [id], onDelete: SetNull)
  numberOfSeats   Int
  status          BookingStatus @default(PENDING)
  cancelledAt     DateTime?
  cancelledBy     String? // 'PASSENGER' | 'DRIVER' | 'ADMIN'
  cancelReason    CancelReason?
  pickupLocation  Json          @db.Json
  dropoffLocation Json          @db.Json
  createdAt       DateTime      @default(now())

  inTransitAt     DateTime?
  passengerComfirmedAt DateTime?
  completedAt     DateTime?
  
  review          Review?
}

model Review {
  id          String        @id @default(cuid())

  bookingId   String        @unique
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  driverId    String? 
  driver      User?          @relation("DriverReviews", fields: [driverId], references: [id], onDelete: SetNull)

  passengerId String?
  passenger   User?          @relation("PassengerReviews", fields: [passengerId], references: [id], onDelete: SetNull)

  rating      Float
  comment     String?

  files       Json? // [{url , type}]
  labels      ReviewLabel[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([driverId, createdAt])
  @@index([passengerId, createdAt])
}

