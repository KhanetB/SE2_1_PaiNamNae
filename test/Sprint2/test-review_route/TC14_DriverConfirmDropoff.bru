meta {
  name: TC14_DriverConfirmDropoff
  type: http
  seq: 16
}

patch {
  url: http://localhost:3000/api/bookings/{{booking_id}}/driver-confirm-dropoff
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{driver_token}}
}

tests {
  test("get HTTP 200", function(){
    const status = res.getStatus();
    expect(status).to.equal(200);
  })
  
  test("update booking status success", function(){
    const body = res.getBody();
    expect(body.success).to.equal(true);
    expect(body.data.status).to.equal("COMPLETED")
  })
}

settings {
  encodeUrl: true
  timeout: 0
}
