meta {
  name: TC12_DriverConfirmBeforePassenger
  type: http
  seq: 14
}

patch {
  url: http://localhost:3000/api/bookings/{{booking_id}}/driver-confirm-dropoff
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{driver_token}}
}

body:json {
  {
    "status": "COMPLETED"
  }
}

tests {
  test("get HTTP 400",function(){
    const status = res.getStatus();
    expect(status).to.equal(400);
  })
}

settings {
  encodeUrl: true
  timeout: 0
}
